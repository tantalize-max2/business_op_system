# ============================================
# 环境变量配置 - 复制此文件为 .env 并填入实际值
# ============================================

# ---- Flask 配置 ----
# 生产环境设为 0（关闭 debug 模式）
FLASK_DEBUG=0

# ---- 邮箱配置（中国电信企业邮箱）----
MAIL_USERNAME=wangy592@chinatelecom.cn
MAIL_PASSWORD=your_password_here
# SMTP 授权码（必填，切勿写入代码，仅从环境变量读取）
MAIL_AUTH_CODE=your_auth_code_here
MAIL_ACCOUNT=wangy592
MAIL_PHONE=your_phone_here

# ---- 安全配置 ----
# API 认证 Token：设置后所有 /api/ 请求需在 X-API-Token 头携带此值
# 留空则不启用认证（仅适合本地开发）；前端通过 localStorage['api-token'] 配合
API_TOKEN=

# CORS 允许的前端来源（逗号分隔），留空则不限制
# 示例：http://10.0.0.1:9527,http://localhost:9527
CORS_ORIGINS=

# ---- 可选：Playwright 浏览器 ----
# Docker 中使用 Playwright 自带 Chromium，通常不需要设置
# PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
